<script>
async function doLogin(){
  const btn=document.getElementById('loginBtn');
  const err=document.getElementById('loginErr');
  const u=document.getElementById('uInput').value.trim();
  const p=document.getElementById('pInput').value.trim();
  if(!u||!p){showErr('Please enter both username and password.');return;}
  btn.disabled=true;btn.textContent='Verifying...';err.classList.remove('show');
  try{
    const [uRes,pRes]=await Promise.all([
      fetch('https://raw.githubusercontent.com/biz-rahul/RKP/main/UR/GF-Pass/user.txt',{cache:'no-store'}),
      fetch('https://raw.githubusercontent.com/biz-rahul/RKP/main/UR/GF-Pass/pass.txt',{cache:'no-store'})
    ]);
    if(!uRes.ok||!pRes.ok)throw new Error('Network error');
    const validUser=(await uRes.text()).trim();
    const validPass=(await pRes.text()).trim();
    if(u===validUser&&p===validPass){
      const ls=document.getElementById('loginScreen');
      ls.style.transition='opacity .5s ease';ls.style.opacity='0';
      setTimeout(()=>{
        ls.style.display='none';
        const ms=document.getElementById('mainSite');ms.style.display='block';
        // staggered card animation
        document.querySelectorAll('.card').forEach((c,i)=>{
          setTimeout(()=>c.classList.add('visible'),i*80);
        });
      },500);
    }else{
      showErr('❌ Wrong username or password. Try again.');
      btn.disabled=false;btn.textContent='Unlock  →';
    }
  }catch(e){
    showErr('⚠️ Network error. Please check your connection.');
    btn.disabled=false;btn.textContent='Unlock  →';
  }
}
function showErr(msg){
  const err=document.getElementById('loginErr');
  err.textContent=msg;err.classList.add('show');
  const box=document.querySelector('.login-box');
  box.style.animation='none';
  setTimeout(()=>{box.style.animation='shake .4s ease';},10);
}
document.addEventListener('keydown',e=>{
  if(e.key==='Enter'&&document.getElementById('loginScreen').style.display!=='none')doLogin();
});
function copyNum(btn,num){
  navigator.clipboard.writeText(num).then(()=>ok(btn)).catch(()=>{
    const t=document.createElement('textarea');t.value=num;document.body.appendChild(t);t.select();
    document.execCommand('copy');document.body.removeChild(t);ok(btn);
  });
}
function ok(btn){
  btn.textContent='✓ Copied!';btn.classList.add('copied');showToast();
  setTimeout(()=>{btn.textContent='📋 Copy';btn.classList.remove('copied');},2200);
}
function showToast(){
  const t=document.getElementById('toast');t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),2400);
}

</script>

